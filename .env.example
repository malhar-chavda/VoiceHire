# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_DEPLOYMENT_FAST=gpt-4.1-mini
AZURE_DEPLOYMENT_SMART=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME=voicehire-uploads

# ── Azure Communication Services (Email) ─────────────────────────────────────
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://your-communication-service.communication.azure.com/;accesskey=your-access-key"
AZURE_SENDER_EMAIL=DoNotReply@your-verified-domain.azurecomm.net

# ── Azure PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=your-postgres-host.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=voicehire
POSTGRES_USER=your-db-username
POSTGRES_PASSWORD=your-db-password
DATABASE_URL=postgresql+asyncpg://your-db-username:your-db-password@your-postgres-host.postgres.database.azure.com:5432/voicehire?ssl=require

# ── FastAPI Server ────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8006
APP_ENV=development

# ── Security / JWT ────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-secret-key-for-jwt-signing
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Recruiter Auth (single user) ──────────────────────────────────────────────
RECRUITER_USERNAME=admin
RECRUITER_PASSWORD=admin123

# ── Frontend / Email Links ────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://127.0.0.1:8006/ui

# ── Interview Thresholds ──────────────────────────────────────────────────────
MATCH_SCORE_THRESHOLD=60
FOLLOW_UP_THRESHOLD=5.5
MAX_FOLLOW_UPS_PER_QUESTION=2
MAX_FOLLOW_UP_QUESTIONS=2
INTERVIEW_TIMEOUT_MINS=60.0
START_INTERVIEW_THRESHOLD=60.0

# ── LangGraph ─────────────────────────────────────────────────────────────────
LANGGRAPH_CHECKPOINTER=postgres
LANGGRAPH_CHECKPOINT_DB=./checkpoints.db

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-3.1-flash-live-preview
