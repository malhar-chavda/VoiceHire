#  AZURE OPENAI 
# Used by: services/azure_openai.py
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_FAST=gpt-4-mini
AZURE_DEPLOYMENT_SMART=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

#  AZURE BLOB STORAGE 
# Used by: services/azure_blob.py
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_STORAGE_CONTAINER_NAME=voicehire-uploads

#  AZURE COMMUNICATION SERVICES (EMAIL) 
AZURE_COMMUNICATION_CONNECTION_STRING=your_azure_communication_connection_string_here
AZURE_SENDER_EMAIL=DoNotReply@YOUR-DOMAIN.com

#  AZURE POSTGRESQL 
# Used by: services/postgres_db.py
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

#  AZURE COGNITIVE SERVICES (TTS / STT) 
# Required for primary voice TTS and optional STT
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

#  WHISPER STT 
# STT_PROVIDER options: "api", "azure", "local"
STT_PROVIDER=api
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL=whisper-1

#  FASTAPI 
# Used by: app/main.py
APP_HOST=0.0.0.0
APP_PORT=8006
APP_ENV=development
SECRET_KEY=change-this-before-production

#  LANGGRAPH 
LANGGRAPH_CHECKPOINTER=sqlite
LANGGRAPH_CHECKPOINT_DB=./checkpoints.db
